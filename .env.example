# ==========================================
# Twilio-SMS-Client Configuration Template
# ==========================================
# Copy to .env and fill in your values
# ==========================================

# --- Profile Selection ---
APP_PROFILE=local

# ==========================================
# DATABASE (Neon PostgreSQL)
# ==========================================
DB_URL=jdbc:postgresql://your-db-host/your-db?sslmode=require
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ==========================================
# SMPP SMSC SIMULATOR (ukarim/smscsim)
# ==========================================
# Local:     SMPP_HOST=localhost  SMPP_PORT=2776
# Docker:    SMPP_HOST=smscsim   SMPP_PORT=2776
# smscsim accepts any credentials, no auth required.

SMPP_HOST=localhost
SMPP_PORT=2776
SMPP_SYSTEM_ID=smppclient
SMPP_PASSWORD=password
SMPP_ADDRESS_RANGE=

# ==========================================
# TWILIO (Optional — per-user in DB)
# ==========================================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SENDER_ID=
