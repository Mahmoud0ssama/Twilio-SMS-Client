DB_URL=jdbc:postgresql://ep-xxxx.neon.tech/neondb?sslmode=require
DB_USER=neondb_owner
DB_PASSWORD=your_db_password

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Global SMSC defaults (used when user has no per‑user SMSC config).
# Set these to use SMPP without per‑user profile configuration.
# SMPP_HOST=127.0.0.1
# SMPP_PORT=2776
# SMPP_SYSTEM_ID=smppclient
# SMPP_PASSWORD=password
# SMPP_ADDRESS_RANGE=